rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Podcast audio files: users can read their own, only backend (admin SDK) writes
    match /users/{userId}/podcasts/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
